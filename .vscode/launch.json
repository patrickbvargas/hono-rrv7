{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run application",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "envFile": "${workspaceFolder}/.env",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["run-script", "dev"],
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}
